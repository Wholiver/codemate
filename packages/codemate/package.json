{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@codemate-ai/cli",
  "version": "1.0.2",
  "description": "Enterprise-grade AI coding assistant CLI",
  "scripts": {
    "build": "bun run script/build.ts",
    "fix-node-pty": "bun run script/fix-node-pty.ts",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "agent",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/codemate.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "private": false,
  "imports": {
    "#db": {
      "bun": "./src/storage/db.bun.ts",
      "node": "./src/storage/db.node.ts",
      "default": "./src/storage/db.bun.ts"
    },
    "#pty": {
      "bun": "./src/pty/pty.bun.ts",
      "node": "./src/pty/pty.node.ts",
      "default": "./src/pty/pty.bun.ts"
    },
    "#httpapi-server": {
      "bun": "./src/server/httpapi-server.node.ts",
      "node": "./src/server/httpapi-server.node.ts",
      "default": "./src/server/httpapi-server.node.ts"
    }
  },
  "bin": {
    "codemate": "./bin/codemate"
  },
