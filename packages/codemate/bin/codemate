#!/usr/bin/env node

const childProcess = require("child_process")
const fs = require("fs")
const path = require("path")

const forwardedSignals = ["SIGINT", "SIGTERM", "SIGHUP"]
const scriptPath = fs.realpathSync(__filename)
const scriptDir = path.dirname(scriptPath)
const cliEntry = path.resolve(scriptDir, "..", "dist", "cli", "index.js")
const bunPath = process.env.codemate_BUN_PATH || "bun"

if (!fs.existsSync(cliEntry)) {
  console.error(`Could not find CLI entry at ${cliEntry}. Please reinstall @codemate-ai/cli.`)
  process.exit(1)
}

const child = childProcess.spawn(bunPath, [cliEntry, ...process.argv.slice(2)], {
  stdio: "inherit",
})

child.on("error", (error) => {
  if (error && error.code === "ENOENT") {
    console.error("Bun is required to run codemate. Install Bun >= 1.3.13 and ensure `bun` is in PATH.")
    process.exit(1)
  }
  console.error(error.message)
  process.exit(1)
})

const forwarders = {}
for (const signal of forwardedSignals) {
  forwarders[signal] = () => {
    try {
      child.kill(signal)
    } catch {
      // Child may already be exiting.
    }
  }
  process.on(signal, forwarders[signal])
}

child.on("exit", (code, signal) => {
  for (const forwardedSignal of forwardedSignals) {
    process.removeListener(forwardedSignal, forwarders[forwardedSignal])
  }

  if (signal) {
    process.kill(process.pid, signal)
    return
  }

  process.exit(typeof code === "number" ? code : 0)
})
